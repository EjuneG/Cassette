# Bug-reporter (Cloudflare Worker). Leave empty to disable.
# These values get inlined into both the renderer bundle (Vite) and the main
# process bundle (esbuild). Anyone with the deployed app can read the secret
# from DevTools or by inspecting the bundle — it is a soft anti-spam token,
# not a true cryptographic secret. Treat accordingly.
VITE_REPORTER_WORKER_URL=
VITE_REPORTER_SECRET=

